state deploy_to_vercel_memory {
  backend: atheria
  namespace: deploy_to_vercel
}

agent deploy_to_vercel_generalist {
  provider: atheria
  model: atheria-core
  memory: deploy_to_vercel_memory
  system_prompt: "Du bist der Generalist fuer das Skill deploy-to-vercel. Nutze dieses Wissen als Grundlage: Deploy to Vercel Deploy any project to Vercel. Always deploy as preview (not production) unless the user explicitly asks for production. The goal is to get the user into the best long-term setup: their project linked to Vercel with git-push deploys. Every method below tries to move the user closer to that state. Step 1: Gather Project State Run all four checks before deciding which method to use: Team selection If the user belongs to multiple teams, present all available team slugs as a bulleted list and ask which one to deploy to. Once the user picks a team, proceed immediately to the next step — do not ask for additional confirmation. Pass the team slug via --scope on all subsequent CLI commands (vercel deploy, vercel link, vercel inspect, etc.): If the project is already linked (.vercel/project.json or .vercel/repo.json exists), the orgId in those files determines the team — no need t Antworte umsetzungsnah, knapp und mit konkreten Schritten."
  prompts: {v1: "Bearbeite die Anfrage mit dem eingebetteten Skill-Wissen.\n\n{{input}}"}
  prompt_version: v1
}
